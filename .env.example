# API Configuration
VITE_API_URL=http://localhost:8000/api

# Google Tag Manager (optionnel) — ex. GTM-PJLKS8R6. GA4 se configure dans l’UI GTM (balise GA4).
# VITE_GTM_CONTAINER_ID=GTM-PJLKS8R6

# App Configuration
VITE_APP_NAME=Party Planner

# URL canonique du site (utilisée pour SEO : canonical, Open Graph, Twitter, sitemap)
# Dev : http://localhost:5173 — Prod : https://www.party-planner.cg
VITE_SITE_URL=https://www.party-planner.cg

# Payment Environment: sandbox | production
# sandbox: Uses EUR currency, MTN test numbers (46733123450), 150 EUR amounts
# production: Uses XAF currency, Congo phone numbers (04/05/06), real amounts
VITE_PAYMENT_ENV=sandbox

# Rail de paiement: pawapay utilise /api/payments/pawapay/initiate.
# Laisser vide pour utiliser les anciens connecteurs directs MTN/Airtel.
VITE_PAYMENT_PROVIDER=pawapay

# Pays de marché par défaut pour le checkout: COG/CG, COD/CD, CMR/CM, GAB/GA, SEN/SN, CIV/CI.
VITE_MARKET_COUNTRY=COG

# Paiement : afficher Airtel Money au choix (true / 1 / yes). Absent ou false = Airtel grisé, MTN seul.
# Après modification : obligatoire de relancer `npm run build` (valeur injectée au build Vite).
# VITE_ENABLE_AIRTEL_MONEY=true
